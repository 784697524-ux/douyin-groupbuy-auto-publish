+import unittest
+
+from uploader.douyin_uploader.product_selector import (
+    build_public_content,
+    parse_product_candidates,
+)
+
+
+class DouyinProductSelectorTests(unittest.TestCase):
+    def test_parse_product_candidates_from_ranking_text(self):
+        text = """
+        商品榜单
+        昨天
+        商品成交券数
+        【慈溪城西】野人先生买一送一资格券【C】
+        ID：7655943912309278735
+        1元
+        商品成交券数
+        405
+        【慈溪城西】奶茶买一送一资格券【C】
+        ID：7655623663969994779
+        商品成交券数
+        276
+        """
+
+        products = parse_product_candidates(text, limit=2)
+
+        self.assertEqual(len(products), 2)
+        self.assertEqual(products[0]["product_id"], "7655943912309278735")
+        self.assertEqual(products[0]["metric"], "商品成交券数")
+        self.assertEqual(products[0]["metric_value"], "405")
+
+    def test_public_content_does_not_include_backend_id_or_metric(self):
+        product = {
+            "name": "【慈溪城西】野人先生买一送一资格券【C】",
+            "product_id": "7655943912309278735",
+            "metric_value": "405",
+            "detail": {"detail_text": "慈溪城西银泰百货 宁波市慈溪市宗汉街道"},
+        }
+
+        public = build_public_content(product)
+
+        self.assertNotIn("7655943912309278735", public["caption"])
+        self.assertNotIn("405", public["caption"])
+        self.assertIn("慈溪城西银泰百货", public["caption"])
+
+
+if __name__ == "__main__":
+    unittest.main()
+
