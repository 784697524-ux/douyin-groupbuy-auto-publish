@@ -0,0 +1,368 @@
+# -*- coding: utf-8 -*-
+from __future__ import annotations
+
+import re
+from datetime import datetime
+from pathlib import Path
+from typing import Any
+from urllib.parse import urljoin
+
+from patchright.async_api import Page
+from patchright.async_api import BrowserContext
+from patchright.async_api import async_playwright
+
+from conf import BASE_DIR, LOCAL_CHROME_HEADLESS
+from utils.base_social_media import set_init_script
+from utils.log import douyin_logger
+
+
+DEFAULT_GROUP_ID = "1748531528342532"
+DATA_LIST_URL = "https://www.life-data.cn/product/my/chain/list?groupid={groupid}"
+LAIKE_HOME_URL = "https://life.douyin.com/p/home?groupid={groupid}"
+GOODS_LIST_URL = "https://life.douyin.com/p/goods-list?groupid={groupid}&industry=tobias"
+
+
+def _clean(text: str) -> str:
+    return re.sub(r"\s+", " ", text or "").strip()
+
+
+def _lines(text: str) -> list[str]:
+    return [line.strip() for line in (text or "").splitlines() if line.strip()]
+
+
+def _looks_like_product_name(line: str) -> bool:
+    if "【" in line and "】" in line:
+        return True
+    return bool(re.search(r"(券|卡|团购|权益|套餐|洗|餐饮|观影|奶茶|冰淇淋)", line))
+
+
+def _pick_name(lines: list[str], index: int) -> str:
+    for offset in range(1, 7):
+        pos = index - offset
+        if pos < 0:
+            break
+        candidate = lines[pos]
+        if _looks_like_product_name(candidate) and len(candidate) <= 80:
+            return candidate
+    return ""
+
+
+def _metric_value(lines: list[str], index: int, metric: str) -> str:
+    metric_keys = [metric, "成交券数", "商品成交券数"]
+    ranges = [(index, min(len(lines), index + 18)), (max(0, index - 12), index)]
+    for start, end in ranges:
+        for i in range(start, end):
+            if not any(key and key in lines[i] for key in metric_keys):
+                continue
+            for j in range(i, min(i + 5, end)):
+                if re.search(r"(?:商品)?ID[:：]?\s*\d{10,}", lines[j]):
+                    continue
+                value = re.search(r"([0-9][0-9,]*(?:\.[0-9]+)?)", lines[j])
+                if value:
+                    return value.group(1)
+    return ""
+
+
+def parse_product_candidates(page_text: str, metric: str = "商品成交券数", limit: int = 3) -> list[dict[str, Any]]:
+    """Parse ranking candidates from the Shengyijing product-ranking page text."""
+    rows: list[dict[str, Any]] = []
+    seen_ids: set[str] = set()
+    lines = _lines(page_text)
+    for index, line in enumerate(lines):
+        match = re.search(r"(?:商品)?ID[:：]?\s*(\d{10,})", line)
+        if not match:
+            continue
+        product_id = match.group(1)
+        if product_id in seen_ids:
+            continue
+        name = _pick_name(lines, index)
+        if not name:
+            continue
+        seen_ids.add(product_id)
+        start = max(0, index - 5)
+        end = min(len(lines), index + 14)
+        rows.append(
+            {
+                "rank": len(rows) + 1,
+                "product_id": product_id,
+                "name": name,
+                "metric": metric,
+                "metric_value": _metric_value(lines, index, metric),
+                "ranking_excerpt": "\n".join(lines[start:end]),
+            }
+        )
+        if len(rows) >= limit:
+            break
+    return rows
+
+
+def build_public_content(product: dict[str, Any], location: str = "") -> dict[str, str]:
+    """Create public-facing copy. Do not expose product IDs or backend sales numbers."""
+    name = _clean(product.get("name", "本地团购卡券"))
+    detail_text = _clean(product.get("detail", {}).get("detail_text", ""))
+    row_text = _clean(product.get("detail", {}).get("row_text", ""))
+    source_text = detail_text or row_text
+    store = location or _guess_store(source_text) or "门店"
+    short_store = store.replace("百货", "").replace("商场", "")
+    product_label = re.sub(r"^【[^】]+】", "", name).replace("【C】", "").strip() or name
+    title = f"{short_store}这张先囤"[:20]
+    caption = (
+        f"最近想逛{store}，这张{product_label}可以先看看。\n\n"
+        "适合顺路逛街、吃喝和到店消费前先囤一张。下单前重点看三件事："
+        "可用门店、使用日期、是否需要额外支付。\n\n"
+        "看到合适就先领，真正到店前再确认规则，别错过本地生活小福利。\n\n"
+        "#本地生活 #银泰百货 #团购券 #逛吃攻略 #同城优惠"
+    )
+    return {
+        "title": title,
+        "caption": caption,
+        "location": store,
+        "product_label": product_label,
+    }
+
+
+def build_image_prompts(product: dict[str, Any], public: dict[str, str]) -> list[str]:
+    name = public["product_label"]
+    store = public["location"]
+    return [
+        (
+            "竖版抖音图文封面海报，真实商场团购推广风格，明亮高点击，"
+            f"主题是{store}本地卡券，主标题突出“先囤再逛”，副标题包含{name}，"
+            "画面像真实门店外景和年轻消费者逛商场，不出现商品ID、成交张数、后台数据。"
+        ),
+        (
+            "竖版团购信息海报，真实生活方式摄影质感，展示消费者逛街前先看券的场景，"
+            f"核心卖点是{name}，强调到店前看可用门店和使用日期，"
+            "排版清晰，适合抖音图文第二张。"
+        ),
+        (
+            "竖版本地生活卡券攻略海报，画面包含手机下单界面氛围、商场灯光、朋友结伴逛吃，"
+            f"地点感为{store}，文案方向是“买前看规则，适合再下单”，"
+            "不要出现后台销量、排名或商品ID。"
+        ),
+        (
+            "竖版行动转化海报，真实人物拿手机准备下单，商场背景清晰，"
+            f"主题为{store}卡券福利，按钮感文案“现在去看看”，"
+            "整体红白高对比，适合抖音图文最后一张引导购买。"
+        ),
+    ]
+
+
+def _guess_store(text: str) -> str:
+    patterns = [
+        r"([\u4e00-\u9fa5A-Za-z0-9（）()·-]{2,24}银泰百货)",
+        r"([\u4e00-\u9fa5A-Za-z0-9（）()·-]{2,24}银泰城)",
+    ]
+    for pattern in patterns:
+        match = re.search(pattern, text)
+        if match:
+            return match.group(1)
+    return ""
+
+
+async def _body_text(page: Page) -> str:
+    return await page.locator("body").inner_text(timeout=20000)
+
+
+async def _click_text(page: Page, text: str, exact: bool = True, timeout: int = 4000) -> bool:
+    locator = page.get_by_text(text, exact=exact)
+    count = await locator.count()
+    for i in range(count):
+        item = locator.nth(i)
+        try:
+            await item.wait_for(state="visible", timeout=timeout)
+            await item.click(force=True, timeout=timeout)
+            await page.wait_for_timeout(800)
+            return True
+        except Exception:
+            continue
+    return False
+
+
+async def _visible_image_urls(page: Page) -> list[str]:
+    return await page.evaluate(
+        """() => Array.from(document.images)
+            .map(img => ({
+                src: img.currentSrc || img.src || "",
+                width: img.naturalWidth || img.width || 0,
+                height: img.naturalHeight || img.height || 0
+            }))
+            .filter(img => img.src && img.width >= 40 && img.height >= 40)
+            .slice(0, 20)
+            .map(img => new URL(img.src, location.href).href)"""
+    )
+
+
+async def _open_ranking_page_from_laike(context: BrowserContext, groupid: str) -> Page:
+    page = await context.new_page()
+    await page.goto(LAIKE_HOME_URL.format(groupid=groupid), wait_until="domcontentloaded", timeout=90000)
+    await page.wait_for_timeout(3000)
+    clicked = await _click_text(page, "生意经", exact=False, timeout=5000)
+    if clicked:
+        await page.wait_for_timeout(5000)
+        for candidate in reversed(context.pages):
+            if "life-data.cn" in candidate.url:
+                page = candidate
+                break
+    await page.goto(DATA_LIST_URL.format(groupid=groupid), wait_until="domcontentloaded", timeout=90000)
+    await page.wait_for_timeout(3500)
+    return page
+
+
+async def _extract_row_text(page: Page, product_id: str) -> str:
+    return await page.evaluate(
+        """productId => {
+            const visible = el => {
+                const style = getComputedStyle(el);
+                const rect = el.getBoundingClientRect();
+                return style.display !== "none" && style.visibility !== "hidden" && rect.width > 0 && rect.height > 0;
+            };
+            const candidates = Array.from(document.querySelectorAll('tr,[class*="row"],[class*="table"],div'))
+                .filter(el => visible(el) && (el.innerText || "").includes(productId))
+                .map(el => (el.innerText || "").trim())
+                .filter(text => text.length > 0 && text.length < 3000)
+                .sort((a, b) => a.length - b.length);
+            return candidates[0] || "";
+        }""",
+        product_id,
+    )
+
+
+async def _click_view_for_product(page: Page, product_id: str) -> bool:
+    return await page.evaluate(
+        """productId => {
+            const visible = el => {
+                const style = getComputedStyle(el);
+                const rect = el.getBoundingClientRect();
+                return style.display !== "none" && style.visibility !== "hidden" && rect.width > 0 && rect.height > 0;
+            };
+            const containers = Array.from(document.querySelectorAll('tr,[class*="row"],[class*="table"],div'))
+                .filter(el => visible(el) && (el.innerText || "").includes(productId) && (el.innerText || "").includes("查看"))
+                .sort((a, b) => (a.innerText || "").length - (b.innerText || "").length);
+            const container = containers[0];
+            if (!container) return false;
+            const target = Array.from(container.querySelectorAll('button,a,span,div'))
+                .find(el => visible(el) && (el.innerText || "").trim() === "查看");
+            if (!target) return false;
+            target.click();
+            return true;
+        }""",
+        product_id,
+    )
+
+
+async def _search_goods_detail(page: Page, product: dict[str, Any], groupid: str) -> dict[str, Any]:
+    product_id = product["product_id"]
+    await page.goto(GOODS_LIST_URL.format(groupid=groupid), wait_until="domcontentloaded", timeout=90000)
+    await page.wait_for_timeout(2500)
+
+    input_selectors = [
+        'input[placeholder*="商品名称/ID"]',
+        'input[placeholder*="商品名称"]',
+        'input[placeholder*="商品ID"]',
+        'input[placeholder*="请输入"]',
+    ]
+    search_input = None
+    for selector in input_selectors:
+        candidate = page.locator(selector).first
+        if await candidate.count():
+            search_input = candidate
+            break
+    if not search_input:
+        raise RuntimeError("未找到来客商品管理搜索框")
+
+    await search_input.fill(product_id)
+    if not await _click_text(page, "查询", exact=True, timeout=5000):
+        await search_input.press("Enter")
+    await page.wait_for_timeout(3000)
+
+    row_text = await _extract_row_text(page, product_id)
+    detail_text = ""
+    detail_url = page.url
+    image_urls = await _visible_image_urls(page)
+    clicked = await _click_view_for_product(page, product_id)
+    if clicked:
+        await page.wait_for_timeout(2500)
+        detail_url = page.url
+        try:
+            detail_text = await _body_text(page)
+            image_urls = await _visible_image_urls(page)
+        except Exception:
+            detail_text = ""
+
+    return {
+        "goods_list_url": GOODS_LIST_URL.format(groupid=groupid),
+        "detail_url": detail_url,
+        "row_text": row_text,
+        "detail_text": detail_text[:12000],
+        "image_urls": image_urls,
+    }
+
+
+async def select_groupbuy_products(
+    account_file: str,
+    groupid: str = DEFAULT_GROUP_ID,
+    date_filter: str = "昨天",
+    metric: str = "商品成交券数",
+    limit: int = 3,
+    headless: bool = LOCAL_CHROME_HEADLESS,
+    debug: bool = True,
+    cdp_url: str | None = None,
+) -> dict[str, Any]:
+    async with async_playwright() as playwright:
+        should_close_browser = True
+        if cdp_url:
+            browser = await playwright.chromium.connect_over_cdp(cdp_url)
+            context = browser.contexts[0] if browser.contexts else await browser.new_context()
+            should_close_browser = False
+        else:
+            browser = await playwright.chromium.launch(
+                headless=headless,
+                channel="chrome",
+                args=["--no-sandbox", "--disable-blink-features=AutomationControlled"],
+            )
+            context = await browser.new_context(storage_state=account_file)
+            context = await set_init_script(context)
+        ranking_page = await _open_ranking_page_from_laike(context, groupid)
+        detail_page = await context.new_page()
+        try:
+            await _click_text(ranking_page, date_filter, exact=True)
+            await _click_text(ranking_page, metric, exact=False)
+            await ranking_page.wait_for_timeout(2500)
+
+            page_text = await _body_text(ranking_page)
+            products = parse_product_candidates(page_text, metric=metric, limit=limit)
+            if not products:
+                raise RuntimeError("没有从生意经商品榜单解析到商品ID，请查看截图和 raw_text")
+
+            for product in products:
+                product["detail"] = await _search_goods_detail(detail_page, product, groupid)
+                public = build_public_content(product)
+                product["public"] = public
+                product["image_prompts"] = build_image_prompts(product, public)
+
+            result = {
+                "generated_at": datetime.now().isoformat(timespec="seconds"),
+                "groupid": groupid,
+                "date_filter": date_filter,
+                "metric": metric,
+                "limit": limit,
+                "ranking_url": ranking_page.url,
+                "products": products,
+            }
+            await context.storage_state(path=account_file)
+            return result
+        except Exception:
+            if debug:
+                log_dir = Path(BASE_DIR) / "logs"
+                log_dir.mkdir(parents=True, exist_ok=True)
+                await ranking_page.screenshot(path=str(log_dir / "douyin_groupbuy_ranking_failed.png"), full_page=True)
+                (log_dir / "douyin_groupbuy_ranking_raw_text.txt").write_text(
+                    await _body_text(ranking_page),
+                    encoding="utf-8",
+                )
+            raise
+        finally:
+            if should_close_browser:
+                await context.close()
+                await browser.close()
