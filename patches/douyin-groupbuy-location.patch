+# -*- coding: utf-8 -*-
+from __future__ import annotations
+
+from pathlib import Path
+from typing import Awaitable, Callable
+
+from patchright.async_api import Page
+
+
+LogFn = Callable[[str], Awaitable[None] | None]
+
+
+async def _log(log: LogFn | None, message: str) -> None:
+    if not log:
+        return
+    result = log(message)
+    if hasattr(result, "__await__"):
+        await result
+
+
+async def _screenshot(page: Page, screenshot_dir: Path | None, name: str) -> None:
+    if not screenshot_dir:
+        return
+    screenshot_dir.mkdir(parents=True, exist_ok=True)
+    await page.screenshot(path=str(screenshot_dir / name), full_page=True)
+
+
+AUTOMA_LOCATION_TRIGGER = ".select-Ht3mEC .semi-select-selection-text"
+AUTOMA_DOMESTIC_TAB = "div.item-text-normal-MC1UEg"
+AUTOMA_LOCATION_INPUT = ".semi-select-input > .semi-input"
+AUTOMA_FIRST_LOCATION_OPTION = ".semi-select-option-focused .detail-v2-uZaTIm"
+
+
+def _normalize_location_text(text: str) -> str:
+    return "".join(ch for ch in text if ch.isalnum())
+
+
+def _location_queries(location: str) -> list[str]:
+    queries: list[str] = []
+
+    def add(query: str) -> None:
+        query = query.strip()
+        if query and query not in queries:
+            queries.append(query)
+
+    if "合肥" in location and "滨湖" in location and "银泰" in location:
+        add("合肥滨湖银泰城")
+        add("滨湖银泰城")
+
+    add(location)
+    add(location.replace("银泰百货", "银泰"))
+    add(location.replace("百货", ""))
+
+    if "慈溪" in location:
+        add("慈溪银泰百货")
+        add("慈溪城西银泰")
+        add("银泰百货(慈溪城西店)")
+
+    return queries
+
+
+def _location_option_score(option_text: str, location: str, query: str) -> int:
+    text = _normalize_location_text(option_text)
+    target = _normalize_location_text(location)
+    query_text = _normalize_location_text(query)
+    first_line = _normalize_location_text((option_text.strip().splitlines() or [""])[0])
+
+    score = 0
+    if target and target in text:
+        score += 120
+    if query_text and query_text in text:
+        score += 100
+    for token in ("合肥", "滨湖", "慈溪", "城西", "银泰", "银泰城", "百货"):
+        if token in location and token in option_text:
+            score += 25
+    if "商场内有多家门店" in option_text:
+        score += 40
+    if "银泰城" in option_text or "百货" in option_text:
+        score += 20
+    if ("店" in first_line or "店" in option_text[:30]) and "店" not in location:
+        score -= 80
+    return score
+
+
+async def _click_first_visible(locator, timeout: int = 5000) -> bool:
+    count = await locator.count()
+    for i in range(count - 1, -1, -1):
+        item = locator.nth(i)
+        try:
+            await item.wait_for(state="visible", timeout=timeout)
+            await item.click(force=True, timeout=timeout)
+            return True
+        except Exception:
+            continue
+    return False
+
+
+async def _first_visible(locator, timeout: int = 5000):
+    count = await locator.count()
+    for i in range(count):
+        item = locator.nth(i)
+        try:
+            await item.wait_for(state="visible", timeout=timeout)
+            return item
+        except Exception:
+            continue
+    return None
+
+
+async def _type_query(page: Page, location_input, query: str) -> None:
+    if location_input:
+        await location_input.click(force=True, timeout=5000)
+        await page.keyboard.press("Meta+A")
+        await page.keyboard.press("Backspace")
+        await location_input.type(query, delay=80)
+        await location_input.dispatch_event("change")
+    else:
+        await page.keyboard.press("Meta+A")
+        await page.keyboard.press("Backspace")
+        await page.keyboard.type(query, delay=80)
+
+
+async def _select_add_tag_value(page: Page, row_label: str, value: str, select_index: int) -> bool:
+    select = page.locator(
+        f'xpath=(//*[normalize-space(.)="{row_label}"]/following::*[contains(@class, "semi-select")])[{select_index}]'
+    )
+    if not await select.count():
+        return False
+    try:
+        current = (await select.inner_text(timeout=2000)).strip()
+        if value in current:
+            await page.keyboard.press("Escape")
+            return True
+        await select.click(force=True, timeout=5000)
+        await page.wait_for_timeout(300)
+        option = page.locator(
+            f'xpath=(//*[contains(@class, "semi-portal") or contains(@class, "semi-popover") or contains(@class, "semi-dropdown")]//*[normalize-space(.)="{value}" or contains(normalize-space(.), "{value}")])[1]'
+        )
+        await option.wait_for(state="visible", timeout=5000)
+        await option.click(force=True, timeout=5000)
+        await page.wait_for_timeout(500)
+        await page.keyboard.press("Escape")
+        await page.wait_for_timeout(200)
+        return True
+    except Exception:
+        return False
+
+
+async def _select_best_location_option(page: Page, location: str, query: str):
+    locators = [
+        page.locator(AUTOMA_FIRST_LOCATION_OPTION),
+        page.locator(".semi-select-option"),
+        page.locator('[role="option"]'),
+        page.locator(".semi-popover .detail-v2-uZaTIm"),
+        page.locator(".semi-portal .detail-v2-uZaTIm"),
+    ]
+    candidates = []
+    for locator in locators:
+        count = min(await locator.count(), 10)
+        for i in range(count):
+            item = locator.nth(i)
+            try:
+                await item.wait_for(state="visible", timeout=1000)
+                text = (await item.inner_text(timeout=1000)).strip()
+            except Exception:
+                continue
+            if not text:
+                continue
+            score = _location_option_score(text, location, query)
+            candidates.append((score, text, item))
+
+    candidates.sort(key=lambda candidate: candidate[0], reverse=True)
+    if not candidates or candidates[0][0] < 70:
+        return ""
+
+    _, selected_text, selected = candidates[0]
+    await selected.click(force=True, timeout=5000)
+    return selected_text
+
+
+async def add_douyin_groupbuy_location(
+    page: Page,
+    location: str,
+    screenshot_dir: Path | None = None,
+    log: LogFn | None = None,
+) -> None:
+    """Select the first domestic POI result after typing the requested location."""
+    location = location.strip()
+    if not location:
+        return
+
+    await _log(log, f"设置地理位置: {location}")
+    await page.evaluate(
+        "() => document.querySelectorAll('.shepherd-element,.shepherd-modal-overlay-container').forEach(e => e.remove())"
+    )
+    await page.keyboard.press("Escape")
+
+    add_tag_label = page.get_by_text("添加标签", exact=True).first
+    await add_tag_label.scroll_into_view_if_needed(timeout=10000)
+
+    if not await _select_add_tag_value(page, "添加标签", "位置", 1):
+        await _screenshot(page, screenshot_dir, "douyin_location_select_position_failed.png")
+        raise RuntimeError("location tag type not selected")
+    if not await _select_add_tag_value(page, "添加标签", "带货模式", 2):
+        await _log(log, "未显式点到带货模式，继续检查位置输入框")
+
+    trigger_clicked = False
+    location_trigger = page.locator(AUTOMA_LOCATION_TRIGGER).first
+    try:
+        await location_trigger.wait_for(state="visible", timeout=10000)
+        await location_trigger.click(force=True, timeout=5000)
+        await page.wait_for_timeout(700)
+        trigger_clicked = True
+    except Exception:
+        fallback_input = await _first_visible(
+            page.locator(
+                'input[placeholder*="输入城市+位置名称搜索"], input[placeholder*="输入相关位置"], input[placeholder*="输入地理位置"]'
+            ),
+            timeout=3000,
+        )
+        if fallback_input:
+            await fallback_input.click(force=True, timeout=5000)
+            await page.wait_for_timeout(500)
+        else:
+            await _screenshot(page, screenshot_dir, "douyin_location_input_not_visible.png")
+            raise
+
+    if trigger_clicked:
+        domestic_tabs = [
+            page.locator(AUTOMA_DOMESTIC_TAB).filter(has_text="国内"),
+            page.locator('.semi-popover:has-text("国内")').get_by_text("国内", exact=True),
+            page.locator('.semi-portal:has-text("国内")').get_by_text("国内", exact=True),
+            page.get_by_text("国内", exact=True),
+        ]
+        try:
+            clicked = False
+            for domestic_tab in domestic_tabs:
+                if await _click_first_visible(domestic_tab, timeout=3000):
+                    clicked = True
+                    break
+            if not clicked:
+                raise RuntimeError("domestic tab not found")
+            await page.wait_for_timeout(500)
+        except Exception:
+            await _screenshot(page, screenshot_dir, "douyin_location_domestic_tab_missing.png")
+            raise RuntimeError("domestic tab not found")
+
+    location_inputs = [
+        page.locator(
+            'xpath=(//*[normalize-space(.)="添加标签"]/following::input[contains(@placeholder, "输入城市+位置名称搜索") or contains(@placeholder, "输入相关位置") or contains(@placeholder, "输入地理位置")])[1]'
+        ),
+        page.locator('input[placeholder*="输入城市+位置名称搜索"]'),
+        page.locator('input[placeholder*="输入相关位置"]'),
+        page.locator(AUTOMA_LOCATION_INPUT),
+    ]
+    location_input = None
+    for candidate in location_inputs:
+        location_input = await _first_visible(candidate, timeout=3000)
+        if location_input:
+            break
+    if not location_input:
+        await _log(log, "未定位到位置输入框，尝试向当前聚焦输入框键盘输入")
+
+    queries = _location_queries(location)
+    selected_text = ""
+    for query in queries:
+        try:
+            await _type_query(page, location_input, query)
+            await page.wait_for_timeout(2500)
+        except Exception:
+            await _screenshot(page, screenshot_dir, "douyin_location_type_failed.png")
+            raise
+        selected_text = await _select_best_location_option(page, location, query)
+        if selected_text:
+            break
+    if not selected_text:
+        await _screenshot(page, screenshot_dir, "douyin_location_options_not_ready.png")
+        raise RuntimeError("location options did not appear after typing")
+
+    await page.wait_for_timeout(1000)
+
+    selected = page.locator(
+        'xpath=(//*[normalize-space(.)="添加标签"]/following::*[contains(normalize-space(.), "银泰") or contains(normalize-space(.), "慈溪")])[1]'
+    ).first
+    try:
+        selected_text = (await selected.inner_text(timeout=3000)).strip()
+    except Exception:
+        selected_text = ""
+    if _location_option_score(selected_text, location, queries[0]) < 70:
+        await _screenshot(page, screenshot_dir, "douyin_location_not_selected.png")
+        raise RuntimeError("location was not selected")
+
+    await _log(log, f"地理位置已选择: {selected_text}")
