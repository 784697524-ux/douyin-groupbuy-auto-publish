+# -*- coding: utf-8 -*-
+from __future__ import annotations
+
+from pathlib import Path
+from typing import Awaitable, Callable
+
+from patchright.async_api import Page
+
+
+LogFn = Callable[[str], Awaitable[None] | None]
+
+AUTOMA_MUSIC_TRIGGER = "span.action-Q1y01k"
+AUTOMA_FIRST_MUSIC_USE = ".card-container-tmocjc:nth-child(1) .semi-button-content"
+
+
+async def _log(log: LogFn | None, message: str) -> None:
+    if not log:
+        return
+    result = log(message)
+    if hasattr(result, "__await__"):
+        await result
+
+
+async def _screenshot(page: Page, screenshot_dir: Path | None, name: str) -> None:
+    if not screenshot_dir:
+        return
+    screenshot_dir.mkdir(parents=True, exist_ok=True)
+    await page.screenshot(path=str(screenshot_dir / name), full_page=True)
+
+
+async def select_first_music_from_automa(
+    page: Page,
+    screenshot_dir: Path | None = None,
+    log: LogFn | None = None,
+) -> bool:
+    await _log(log, "按 Automa 链路选择第一首推荐音乐")
+    await page.locator("html").evaluate("el => window.scrollBy({ top: 452, behavior: 'smooth' })")
+    await page.wait_for_timeout(800)
+
+    trigger = page.locator(AUTOMA_MUSIC_TRIGGER).first
+    try:
+        await trigger.wait_for(state="visible", timeout=10000)
+        await trigger.click(force=True, timeout=5000)
+    except Exception:
+        await _screenshot(page, screenshot_dir, "douyin_music_trigger_not_found.png")
+        raise
+
+    use_button = page.locator(AUTOMA_FIRST_MUSIC_USE).first
+    try:
+        await use_button.wait_for(state="attached", timeout=15000)
+        await use_button.evaluate(
+            """el => {
+                const button = el.closest('button') || el;
+                button.click();
+            }"""
+        )
+        await page.wait_for_timeout(1000)
+    except Exception:
+        await _screenshot(page, screenshot_dir, "douyin_music_first_use_not_found.png")
+        raise
+
+    await _log(log, "第一首推荐音乐已选择")
+    return True
